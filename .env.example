# Firebase Console → Project settings → Your apps → Web app → SDK setup and configuration.
# Not a secret — this is a public client identifier, safe to embed in the built bundle.
# Copy this file to .env.local (gitignored) and fill in real values.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Fine-grained PAT, Contents: Read-only on KlukvaGames/preess-or-die (same repo/scope as the SPRITE_REPO_TOKEN
# GitHub Actions secret used by .github/workflows/deploy.yml). Powers the Sources page's "Подгрузить спрайты"
# button in `npm run dev` (see scripts/sync-sprites.mjs) — read server-side only via vite.config.ts, deliberately
# NOT prefixed VITE_ so it's never bundled into client code or the deployed site. Leave blank if you don't need it.
SPRITE_REPO_TOKEN=

# Shared secret the Sources page's "Экспортировать правки" sends to the Apps Script's doPost handler (see
# docs/apps-script-export.gs) so the write endpoint isn't wide open to anyone who has the URL. Must match the
# EXPORT_TOKEN Script Property set on that Apps Script project exactly. This IS bundled into client code (VITE_
# prefix) — it's a modest deterrent against casual/accidental writes, not real access control (there's no user
# auth in this app at all, same tradeoff as Firestore's open rules) — treat it as a shared team password, not a secret.
VITE_SHEETS_EXPORT_TOKEN=
