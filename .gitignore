# Synced locally from the game repo by the Sources page's "Подгрузить спрайты" button (scripts/sync-sprites.mjs)
# — bulk game assets, not meant to be committed, EXCEPT public/roulette_interface/pod-mini-characters/, which is
# intentionally checked in (same as before this all lived under public/roulette_interface/) — the "!" negation
# below only works because this ignores the directory's *contents* (trailing /*), not the directory itself.
public/roulette_interface/*
!public/roulette_interface/pod-mini-characters

